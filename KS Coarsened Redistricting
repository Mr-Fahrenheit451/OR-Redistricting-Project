    "from coarsen import graph_coarsen_by_county\n",
    "\n",
    "#All counties except Johnson will be combined from their precincts\n",
    "(CJ, _) = graph_coarsen_by_county(J, granular_fips = ['20091'])\n",
    "#returns graph and partitions "
   ]
  },
  {
   "cell_type": "code",
