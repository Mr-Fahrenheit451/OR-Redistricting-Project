    "# ── PRECINCT DECISION VARIABLES ───────────────────────────────────────────────\n",
    "# x_vtd[i,j] = 1  iff precinct i is assigned to district j\n",
    "x_vtd = m.addVars(G_vtd.nodes, k, vtype=GRB.BINARY, name=\"x_vtd\")\n",
    "\n",
    "# Each precinct must be assigned to exactly one district\n",
    "m.addConstrs(\n",
    "    gp.quicksum(x_vtd[i, j] for j in range(k)) == 1\n",
    "    for i in G_vtd.nodes\n",
    ")\n",
    "\n",
    "# ── PRECINCT CONTIGUITY (Hojny et al. 2021) ───────────────────────────────────\n",
    "# Root variables for the precinct graph\n",
    "r_vtd = m.addVars(G_vtd.nodes, k, vtype=GRB.BINARY, name=\"r_vtd\")\n",
    "\n",
    "# Directed version of the precinct graph for flow variables\n",
    "DG_vtd = nx.DiGraph(G_vtd)\n",
    "f_vtd  = m.addVars(DG_vtd.edges, name=\"f_vtd\")\n",
    "\n",
    "M_vtd = G_vtd.number_of_nodes() - k + 1   # big-M for precinct graph\n",
    "\n",
    "# Each district has exactly one precinct root\n",
    "m.addConstrs(\n",
    "    gp.quicksum(r_vtd[i, j] for i in G_vtd.nodes) == 1\n",
    "    for j in range(k)\n",
    ")\n",
    "\n",
    "# A precinct can only be a root if it is assigned to that district\n",
    "m.addConstrs(\n",
    "    r_vtd[i, j] <= x_vtd[i, j]\n",
    "    for i in G_vtd.nodes for j in range(k)\n",
    ")\n",
    "\n",
    "# Flow-balance: non-roots consume flow; roots only emit\n",
    "m.addConstrs(\n",
    "    gp.quicksum(f_vtd[nb_node, i] - f_vtd[i, nb_node]\n",
    "                for nb_node in G_vtd.neighbors(i))\n",
    "    >= 1 - M_vtd * gp.quicksum(r_vtd[i, j] for j in range(k))\n",
    "    for i in G_vtd.nodes\n",
    ")\n",
    "\n",
    "# Cut-edge coupling: no flow across edges whose endpoints are in different districts\n",
    "y_vtd = m.addVars(G_vtd.edges, vtype=GRB.BINARY, name=\"y_vtd\")\n",
    "\n",
    "m.addConstrs(\n",
    "    x_vtd[u, j] - x_vtd[v, j] <= y_vtd[u, v]\n",
    "    for u, v in G_vtd.edges for j in range(k)\n",
    ")\n",
    "\n",
    "m.addConstrs(\n",
    "    f_vtd[i, j] + f_vtd[j, i] <= M_vtd * (1 - y_vtd[i, j])\n",
    "    for i, j in G_vtd.edges\n",
    ")\n",
    "\n",
    "# ── COUNTY–PRECINCT CONSISTENCY ───────────────────────────────────────────────\n",
    "# If precinct i belongs to county c (identified via COUNTYFP20 / GEOID20\n",
    "# prefix), ensure they are assigned to the same district.\n",
    "# Build a mapping: county_geoid -> list of precinct nodes\n",
    "from collections import defaultdict\n",
    "county_to_precincts = defaultdict(list)\n",
    "for node in G_vtd.nodes:\n",
    "    # VTD GEOID20 is typically a 10-digit string; the first 5 digits are the\n",
    "    # county FIPS code.  Adjust the slice if your data differs.\n",
    "    county_fips = str(G_vtd.nodes[node]['GEOID20'])[:5]\n",
    "    county_to_precincts[county_fips].append(node)\n",
    "\n",
    "# Build reverse map: county graph node -> county FIPS\n",
    "county_node_to_fips = { i : str(G.nodes[i]['GEOID20']) for i in G.nodes }\n",
    "\n",
    "for county_node, county_fips in county_node_to_fips.items():\n",
    "    for precinct_node in county_to_precincts.get(county_fips, []):\n",
    "        for j in range(k):\n",
    "            # x[county, j] == x_vtd[precinct, j]\n",
    "            m.addConstr(x_vtd[precinct_node, j] == x[county_node, j])\n",
    "\n",
    "m.update()\n",
    "print(\"Precinct contiguity constraints added successfully.\")\n"
