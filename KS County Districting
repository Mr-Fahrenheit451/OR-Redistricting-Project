   "source": [
    "import math\n",
    "dev = 0.01\n",
    "k = 4 \n",
    "total_pop = sum( K.nodes[node]['POP'] for node in K.nodes )\n",
    "\n",
    "L = math.ceil( ( 1 - dev / 2 ) * total_pop / k )\n",
    "U = math.floor( ( 1 + dev / 2 ) * total_pop / k )\n",
    "print(\"Using L =\",L,\"and U =\",U,\"and k =\",k)"
   ]
  },
  {
   "cell_type": "code",
