   "source": [
    "\n",
    "# Read Oklahoma county graph from the json file \"OK_county.json\"\n",
    "path = \"C:/Users/kailu/OneDrive/Documents/1 OR Project/\"\n",
    "name = 'KS_county.json'\n",
    "\n",
    "K = read_graph_from_json( path + name )"
   ]
  },
  {
